    <meta property="og:title" content="Piace Batterie | Batterie Auto e Industriali a Piacenza" />
    <meta property="og:description" content="Controllo batteria gratuito in 5 minuti. Vendita, assistenza e installazione senza appuntamento a Piacenza." />
    <meta property="og:url" content="https://piacebatterie.it/" />
    <meta property="og:image" content="https://piacebatterie.it/images/og-image.jpg" />
    <meta property="og:locale" content="it_IT" />

    <!-- TWITTER -->
    <meta name="twitter:card" content="summary_large_image" />
