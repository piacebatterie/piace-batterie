---
import "../styles/global.css";
import Header from "../components/Header.astro";
import "../styles/button.css";
import "../styles/sticky.css";
import Footer from "../components/Footer.astro";
import FreeCheck from '../components/cta/FreeCheck.astro';
import LocationModal from "../components/LocationModal.astro";
import CookieBanner from "../components/CookieBanner.astro";
---

<!DOCTYPE html>
<html lang="it">
  <head>
    <meta charset="UTF-8" />
   <meta name="format-detection" content="telephone=no, email=no">

    <!-- RESPONSIVE -->
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- SEO BASE -->
    <title>Piace Batterie | Batterie Auto e Industriali a Piacenza</title>

    <meta name="description" content="Vendita e assistenza batterie auto e industriali a Piacenza. Controllo gratuito immediato, senza appuntamento. Intervento rapido e professionale." />

    <meta name="keywords" content="batterie auto Piacenza, batterie industriali, sostituzione batteria, assistenza batterie, controllo batteria gratuito" />

    <meta name="author" content="Piace Batterie" />

    <!-- OPEN GRAPH (SOCIAL) -->
    <meta property="og:title" content="Piace Batterie | Batterie Auto a Piacenza" />
    <meta property="og:description" content="Controllo batteria gratuito immediato. Nessuna attesa, nessun appuntamento. Servizio rapido e professionale a Piacenza." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://www.piacebatterie.it/" />
    <meta property="og:image" content="/og-image.jpg" />

    <!-- TWITTER -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Piace Batterie" />
    <meta name="twitter:description" content="Controllo batteria gratuito immediato a Piacenza." />
    <meta name="twitter:image" content="/og-image.jpg" />

    <!-- FAVICON -->
    <link rel="icon" href="/favicon.ico" />

    <!-- PERFORMANCE -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

    <!-- FONT -->
    <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;600;700&display=swap" rel="stylesheet">

    <!-- THEME COLOR (mobile browser) -->
    <meta name="theme-color" content="#020814" />

    <!-- CANONICAL -->
    <link rel="canonical" href="https://www.piacebatterie.it/" />
  </head>

  <body>
    <Header />

    <main>
      <slot />
<LocationModal />
        <FreeCheck />
        <CookieBanner />
    </main>

    <Footer />

    <div class="sticky-cta">
  <a href="tel:+3905231656743" class="sticky-call">
    📞 Chiama ora
  </a>
</div>

<script>
document.addEventListener("DOMContentLoaded", () => {

  /* =====================================================
     REVEAL ON SCROLL
  ===================================================== */
  const initReveal = () => {
    const groups = document.querySelectorAll(".reveal-group");
    const singles = document.querySelectorAll(".reveal:not(.card)");

    const observer = new IntersectionObserver((entries, obs) => {
      entries.forEach(entry => {
        if (!entry.isIntersecting) return;

        if (entry.target.classList.contains("reveal-group")) {
          const items = entry.target.querySelectorAll(".reveal");

          items.forEach((el, index) => {
            setTimeout(() => el.classList.add("in-view"), index * 160);
          });

        } else {
          entry.target.classList.add("in-view");
        }

        obs.unobserve(entry.target);
      });
    }, { threshold: 0.65 });

    groups.forEach(el => observer.observe(el));
    singles.forEach(el => observer.observe(el));
  };


  /* =====================================================
     CARD 3D
  ===================================================== */
  const initCard3D = () => {
    document.querySelectorAll(".card").forEach(card => {

      let frame;

      card.addEventListener("mousemove", e => {
        cancelAnimationFrame(frame);

        frame = requestAnimationFrame(() => {
          const rect = card.getBoundingClientRect();

          const x = e.clientX - rect.left;
          const y = e.clientY - rect.top;

          const midX = rect.width / 2;
          const midY = rect.height / 2;

          const rotateY = ((x - midX) / midX) * 5;
          const rotateX = ((midY - y) / midY) * 5;

          card.style.transform = `
            rotateX(${rotateX}deg)
            rotateY(${rotateY}deg)
            scale(1.02)
          `;

          card.style.setProperty("--x", `${x}px`);
          card.style.setProperty("--y", `${y}px`);
        });
      });

      card.addEventListener("mouseleave", () => {
        card.style.transform = "";
      });
    });
  };


  /* =====================================================
     CTA GLOW
  ===================================================== */
  const initCtaGlow = () => {
    const cta = document.querySelector(".cta");
    if (!cta) return;

    let targetX = 0, targetY = 0;
    let currentX = 0, currentY = 0;

    cta.addEventListener("mousemove", (e) => {
      const rect = cta.getBoundingClientRect();
      targetX = e.clientX - rect.left;
      targetY = e.clientY - rect.top;
    });

    const animate = () => {
      currentX += (targetX - currentX) * 0.08;
      currentY += (targetY - currentY) * 0.08;

      cta.style.setProperty("--lx", `${currentX}px`);
      cta.style.setProperty("--ly", `${currentY}px`);

      requestAnimationFrame(animate);
    };

    animate();
  };


  /* =====================================================
     BUTTON GLOW
  ===================================================== */
  const initButtonGlow = () => {
    document.querySelectorAll(".btn").forEach(btn => {
      btn.addEventListener("mousemove", (e) => {
        const rect = btn.getBoundingClientRect();
        btn.style.setProperty("--lx", `${e.clientX - rect.left}px`);
        btn.style.setProperty("--ly", `${e.clientY - rect.top}px`);
      });
    });
  };


  /* =====================================================
     SERVICES PARALLAX (throttled)
  ===================================================== */
  const initServicesParallax = () => {
    const services = document.querySelector(".services");
    if (!services) return;

    let ticking = false;

    window.addEventListener("scroll", () => {
      if (!ticking) {
        requestAnimationFrame(() => {
          const rect = services.getBoundingClientRect();
          const offset = Math.max(-200, Math.min(200, rect.top * 0.12));
          services.style.setProperty("--parallaxY", `${offset}px`);
          ticking = false;
        });
        ticking = true;
      }
    });
  };


  /* =====================================================
     BRANDS ANIMATION
  ===================================================== */
  const initBrands = () => {
    const logos = document.querySelectorAll(".brands-grid img");

    logos.forEach((logo, i) => {
      logo.style.opacity = "0";
      logo.style.transform = "translateY(20px)";

      setTimeout(() => {
        logo.style.transition = "all 0.5s ease";
        logo.style.opacity = "0.5";
        logo.style.transform = "translateY(0)";
      }, i * 70);
    });
  };


  /* =====================================================
     STICKY CTA
  ===================================================== */
  const initStickyCTA = () => {
    const cta = document.querySelector(".sticky-cta");
    const footer = document.querySelector("footer");

    if (!cta) return;

    window.addEventListener("scroll", () => {
      const scrollY = window.scrollY;

      cta.classList.toggle("visible", scrollY > 300);

      if (footer) {
        const rect = footer.getBoundingClientRect();
        cta.style.opacity = rect.top < window.innerHeight ? "0" : "";
      }
    });
  };


  /* =====================================================
     MOBILE MENU SWIPE (clean)
  ===================================================== */
  const initMobileMenuSwipe = () => {
    const nav = document.querySelector(".nav");
    const overlay = document.querySelector(".menu-overlay");
    const header = document.querySelector(".header");

    if (!nav || !overlay || !header) return;

    let startY = 0;
    let currentY = 0;
    let isDragging = false;

    const reset = () => {
      nav.style.transform = "";
      nav.style.opacity = "";
    };

    nav.addEventListener("touchstart", (e) => {
      startY = e.touches[0].clientY;
      isDragging = true;
    });

    nav.addEventListener("touchmove", (e) => {
      if (!isDragging) return;

      e.preventDefault();

      currentY = e.touches[0].clientY;
      const delta = currentY - startY;

      if (delta > 0) {
        nav.style.transform = `translateY(${delta}px)`;
        nav.style.opacity = `${1 - delta / 280}`;
      }
    }, { passive: false });

    nav.addEventListener("touchend", () => {
      isDragging = false;

      const delta = currentY - startY;

      if (delta > 120) {
        nav.classList.remove("active");
        overlay.classList.remove("active");
        header.classList.remove("menu-open");
      }

      reset();
      startY = currentY = 0;
    });

    overlay.addEventListener("click", reset);
  };


  /* =====================================================
     INIT ALL
  ===================================================== */
  initReveal();
  initCard3D();
  initCtaGlow();
  initButtonGlow();
  initServicesParallax();
  initBrands();
  initStickyCTA();
  initMobileMenuSwipe();

});
</script>
  </body>
</html>