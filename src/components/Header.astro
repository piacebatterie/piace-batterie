---
import "../styles/header.css";
---

<header class="header">
  <div class="container header-inner">
<!-- LOGO -->
<div class="logo">
  <a href="/" aria-label="Homepage Piace Batterie">
    <img 
      src="/logo_piace_batterie.webp" 
      alt="Piace Batterie - Batterie auto e industriali a Piacenza"
      width="160"
      height="40"
      loading="eager"
      decoding="async"
    />
  </a>
</div>

<!-- NAV -->
<nav class="nav" aria-label="Navigazione principale">
  <a href="/">Home</a>
  <a href="/prodotti">Prodotti</a>
  <a href="/servizi">Servizi</a>
  <a href="/contatti">Contatti</a>
</nav>

<!-- CTA DESKTOP -->
<div class="header-cta">
  <a href="tel:+3905231656743" class="btn primary">
    Chiama ora
  </a>
</div>

<!-- MENU TOGGLE -->
<button 
  class="menu-toggle" 
  id="menuToggle"
  aria-label="Apri menu"
  aria-expanded="false"
>
  <span></span>
  <span></span>
  <span></span>
</button>

  </div>
</header>

<!-- OVERLAY -->

<div class="menu-overlay" id="menuOverlay"></div>


<!-- =========================
     SCRIPT
========================= -->
<script is:inline>
document.addEventListener("DOMContentLoaded", () => {

  const toggle = document.getElementById("menuToggle");
  const nav = document.querySelector(".nav");
  const header = document.querySelector(".header");
  const overlay = document.querySelector(".menu-overlay");

  if (!toggle || !nav || !overlay || !header) return;

  const openMenu = () => {
    nav.classList.add("active");
    overlay.classList.add("active");
    header.classList.add("menu-open");
    document.body.classList.add("menu-open");

    toggle.setAttribute("aria-expanded", "true");
  };

  const closeMenu = () => {
    nav.classList.remove("active");
    overlay.classList.remove("active");
    header.classList.remove("menu-open");
    document.body.classList.remove("menu-open");

    toggle.setAttribute("aria-expanded", "false");
  };

  toggle.addEventListener("click", () => {
    nav.classList.contains("active") ? closeMenu() : openMenu();
  });

  overlay.addEventListener("click", closeMenu);

});
</script>
