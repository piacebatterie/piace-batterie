---
import "../styles/location-modal.css";
---

<div class="location-modal" id="locationModal">
  <div class="modal-overlay"></div>

  <div class="modal-box">

    <button class="modal-close" id="closeModal">×</button>

    <div class="modal-content">

      <p class="modal-badge">📍 Dove siamo</p>

      <h3>
        Vieni senza appuntamento
      </h3>

      <p class="modal-address">
        Str. della Orsina, 46 C<br />
        Piacenza (PC)
      </p>

      <div class="modal-actions">
        <a 
          href="https://www.google.com/maps?q=Str.+della+Orsina+46+C,+Piacenza"
          target="_blank"
          class="btn primary"
        >
          Apri su Maps
        </a>

        <a href="tel:+3905231656743" class="btn secondary">
          Chiama ora
        </a>
      </div>

    </div>
  </div>
</div>

<script>
  const modal = document.getElementById('locationModal');

  document.querySelectorAll('.open-location').forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      modal.classList.add('active');
    });
  });

  document.getElementById('closeModal').addEventListener('click', () => {
    modal.classList.remove('active');
  });

  modal.querySelector('.modal-overlay').addEventListener('click', () => {
    modal.classList.remove('active');
  });
</script>