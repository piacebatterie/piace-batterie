---
import "../styles/components/cookie-banner.css";
---

<div class="cookie-banner" id="cookieBanner">
  <div class="cookie-content">
    <p>
      Questo sito utilizza esclusivamente cookie tecnici necessari al suo funzionamento.
      <a href="/privacy">Scopri di più</a>
    </p>
  </div>

  <div class="cookie-actions">
    <button class="btn primary" id="closeCookies">
      Ho capito
    </button>
  </div>
</div>

<script is:inline>
document.addEventListener("DOMContentLoaded", () => {

  const banner = document.getElementById("cookieBanner");
  const closeBtn = document.getElementById("closeCookies");

  if (!banner) return;

  const seen = localStorage.getItem("cookieSeen");

  if (seen) {
    banner.style.display = "none";
  }

  closeBtn?.addEventListener("click", () => {
    localStorage.setItem("cookieSeen", "true");

    banner.classList.add("hide");

    setTimeout(() => {
      banner.style.display = "none";
    }, 300);
  });

});
</script>