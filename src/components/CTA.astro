---
import "../styles/cta.css";
---

<section class="cta">
  <div class="container cta-inner">

    <!-- micro badge -->
    <div class="cta-badge">
      ⚡ Controllo gratuito immediato
    </div>

    <!-- titolo -->
    <h2>
      La batteria ti lascerà.<br />
      <span>La domanda è: quando?</span>
    </h2>

    <!-- testo -->
    <p>
      Evita brutte sorprese. Controllo professionale in 5 minuti,
      senza appuntamento e senza impegno.
    </p>

    <!-- azioni -->
    <div class="cta-actions">
      <a href="#" class="btn primary lg">Controllo gratuito</a>
      <a href="#" class="btn secondary lg">Chiama ora</a>
    </div>

    <!-- trust -->
    <div class="cta-trust">
      ✔ Nessun costo • ✔ Nessuna attesa • ✔ Risposta immediata
    </div>

  </div>
</section>