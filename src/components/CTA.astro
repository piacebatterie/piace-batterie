---
import "../styles/cta.css";
---

<section class="cta">
  <div class="container cta-inner">

    <!-- micro badge -->
    <div class="cta-badge">
      ⚡ Controllo gratuito immediato
    </div>

    <!-- titolo -->
    <h2>
      La batteria ti lascerà.<br />
      <span>La domanda è: quando?</span>
    </h2>

    <!-- testo -->
    <p>
      Evita brutte sorprese.
      In 5 minuti sai esattamente lo stato della tua batteria —
      senza appuntamento, senza costi, senza impegno.
    </p>

    <!-- azioni -->
    <div class="cta-actions">
     <a href="#" class="btn primary open-cta">Controllo gratuito</a>

      <a href="tel:+3905231656743" class="btn secondary lg">Chiama ora</a>
    </div>

    <!-- note -->
   <div class="cta-note">
  Intervento rapido a Piacenza e provincia.
</div>

  </div>
</section>